{
  "name": "Executive Reporting Pipeline",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 1 * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300],
      "notes": "Runs on 1st of each month at 8am. Adjust cron for your schedule."
    },
    {
      "parameters": {
        "url": "={{ $env.ERP_API_URL }}/api/kpis",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.ERP_API_TOKEN }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "period",
              "value": "={{ $now.minus({months: 1}).format('yyyy-MM') }}"
            },
            {
              "name": "company_id",
              "value": "={{ $env.COMPANY_ID }}"
            }
          ]
        }
      },
      "id": "fetch-kpis",
      "name": "Fetch KPIs from ERP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300],
      "notes": "Replace ERP_API_URL with your actual ERP endpoint."
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst period = $now.minus({months: 1}).format('yyyy-MM');\n\nreturn [{\n  json: {\n    company_id: $env.COMPANY_ID || 'COMPANY-001',\n    period: period,\n    report_type: 'executive',\n    send_email: true,\n    send_slack: true,\n    slack_channel: $env.SLACK_CHANNEL || '#reports',\n    recipients: ($env.EMAIL_RECIPIENTS || '').split(',').filter(e => e),\n    data: {\n      revenue: data.revenue || {},\n      profitability: data.profitability || {},\n      liquidity: data.liquidity || {},\n      operations: data.operations || {}\n    }\n  }\n}];"
      },
      "id": "transform-data",
      "name": "Transform & Validate Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "notes": "Transforms ERP data into report request format."
    },
    {
      "parameters": {
        "url": "={{ $env.REPORTING_API_URL }}/webhook/report",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "company_id",
              "value": "={{ $json.company_id }}"
            },
            {
              "name": "period",
              "value": "={{ $json.period }}"
            },
            {
              "name": "report_type",
              "value": "={{ $json.report_type }}"
            },
            {
              "name": "data",
              "value": "={{ $json.data }}"
            },
            {
              "name": "recipients",
              "value": "={{ $json.recipients }}"
            },
            {
              "name": "slack_channel",
              "value": "={{ $json.slack_channel }}"
            },
            {
              "name": "send_email",
              "value": "={{ $json.send_email }}"
            },
            {
              "name": "send_slack",
              "value": "={{ $json.send_slack }}"
            }
          ]
        }
      },
      "id": "trigger-report",
      "name": "Trigger Report Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 300],
      "notes": "Calls FastAPI backend to start the report generation pipeline."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "status-check",
              "leftValue": "={{ $json.status }}",
              "rightValue": "processing",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-status",
      "name": "Check Pipeline Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL || '#reports' }}",
        "text": "✅ Executive Report pipeline started successfully!\n*Report ID:* `{{ $('trigger-report').item.json.report_id }}`\n*Period:* {{ $('transform-data').item.json.period }}\n*Company:* {{ $('transform-data').item.json.company_id }}\n\nReport will be delivered via email and Slack when ready.",
        "otherOptions": {}
      },
      "id": "slack-success",
      "name": "Slack — Pipeline Started",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [1340, 200],
      "notes": "Notifies Slack that pipeline started successfully."
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL || '#reports' }}",
        "text": "❌ Executive Report pipeline failed!\n*Error:* {{ $json.message }}\n*Period:* {{ $('transform-data').item.json.period }}\n\nPlease check the reporting API logs.",
        "otherOptions": {}
      },
      "id": "slack-error",
      "name": "Slack — Error Alert",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [1340, 400],
      "notes": "Sends error alert to Slack if pipeline fails."
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [{"node": "Fetch KPIs from ERP", "type": "main", "index": 0}]
      ]
    },
    "Fetch KPIs from ERP": {
      "main": [
        [{"node": "Transform & Validate Data", "type": "main", "index": 0}]
      ]
    },
    "Transform & Validate Data": {
      "main": [
        [{"node": "Trigger Report Pipeline", "type": "main", "index": 0}]
      ]
    },
    "Trigger Report Pipeline": {
      "main": [
        [{"node": "Check Pipeline Status", "type": "main", "index": 0}]
      ]
    },
    "Check Pipeline Status": {
      "main": [
        [{"node": "Slack — Pipeline Started", "type": "main", "index": 0}],
        [{"node": "Slack — Error Alert", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": ["reporting", "automation", "ai", "executive"]
}
